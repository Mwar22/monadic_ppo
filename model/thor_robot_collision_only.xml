<mujoco model="thor_robot">
<!---
  <option iterations="50" timestep="0.001" solver="auto" gravity="0 0 -9.81" />
-->
  <compiler angle="radian" meshdir="meshes" eulerseq="zyx" autolimits="true" />

  <default>
    <joint limited="true" damping="0.01" armature="0.01" frictionloss="0.01" />
    <geom condim="4" contype="1" conaffinity="15" friction="0.9 0.2 0.2" solref="0.001 2" />
    <motor ctrllimited="true" />
    <equality solref="0.001 2" />
    <default class="visualgeom">
      <geom material="visualgeom" condim="1" contype="0" conaffinity="0" />
    </default>
  </default>

  <asset>
    <texture name="texplane" type="2d" builtin="checker" rgb1=".0 .0 .0" rgb2=".8 .8 .8" width="100" height="100" />
    <material name="matplane" reflectance="0." texture="texplane" texrepeat="1 1" texuniform="true" />
    <material name="visualgeom" rgba="0.5 0.9 0.2 1" />

    <!-- Adicionado para deixar meshes simplificados para colisão -->
    <mesh name="art1_3d_convexhull" content_type="model/obj" file="art1_3d_convexhull.obj" scale="0.001 0.001 0.001" />
    <mesh name="art2_3d_convexhull" content_type="model/obj" file="art2_3d_convexhull.obj" />
    <mesh name="art3_3d_convexhull" content_type="model/obj" file="art3_3d_convexhull.obj" />
    <mesh name="art4_3d_convexhull" content_type="model/obj" file="art4_3d_convexhull.obj" />
    <mesh name="art5_3d_convexhull" content_type="model/obj" file="art5_3d_convexhull.obj" />
    <mesh name="art6_3d_convexhull" content_type="model/obj" file="art6_3d_convexhull.obj" />
    <mesh name="base_convexhull" content_type="model/obj" file="base_convexhull.obj" />
  </asset>

  <worldbody>
    <light directional="true" diffuse="0.4 0.4 0.4" specular="0.1 0.1 0.1" pos="0 0 5.0" dir="0 0 -1" castshadow="false" />
    <light directional="true" diffuse="0.6 0.6 0.6" specular="0.2 0.2 0.2" pos="0 0 4" dir="0 0 -1" />
    <!--
    <geom name="ground" type="plane" pos="0 0 0" size="100 100 0.001" quat="1 0 0 0" material="matplane" condim="3" conaffinity="15" />
    0.12728801915086668
    -->
    <camera name="fixed" pos="0 -3.0 0.6272880191508667" xyaxes="1 0 0 0 0 1" fovy="30"/>
    <camera name="track" mode="trackcom" pos="0 -3.0 0.6272880191508667" xyaxes="1 0 0 0 0 1" />
    <body name="root" pos="0 0 0" quat="1 0 0 0">

      <!-- Como o braço vai ficar fixo, não precisamos desta junta
      <freejoint name="root" />
      -->
      <site name="imu" size="0.01" pos="0 0 0" />
      <geom name="base_collision" type="mesh" mesh="base_convexhull" contype="1" conaffinity="0" density="0" group="1" class="visualgeom" />

      <body name="Art1_3d_link" pos="0 0 0.098">
        <inertial pos="-1e-06 0 0.061834" mass="0.001" diaginertia="1.3e-05 1.3e-05 1e-05" />
        <joint name="junta1" pos="0 0 0" axis="0 0 1" range="-1.57 1.57" />
        <geom name="Art1_3d_collision" type="mesh" mesh="art1_3d_convexhull" contype="1" conaffinity="0" density="0" group="1" class="visualgeom" />
       
        <body name="art2_3d_link" pos="0 0 0.098" quat="0.707107 -0.707107 0 0">
          <inertial pos="0 -0.08 0" mass="0.001" diaginertia="1.5e-05 1.3e-05 1e-05" />
          <joint name="junta2" pos="0 0 0" axis="0 0 1" range="-1.57 1.57" />
          <geom name="art2_3d_collision" quat="0.707107 0.707107 0 0" type="mesh" mesh="art2_3d_convexhull" contype="1" conaffinity="0" density="0" group="1" class="visualgeom" />
         
          <body name="art3_3d_link" pos="0 -0.16 0">
            <inertial pos="0 -0.021415 -1e-06" mass="0.001" diaginertia="1.3e-05 1.3e-05 1e-05" />
            <joint name="junta3" pos="0 0 0" axis="0 0 1" range="-1.57 1.57" />
            <geom name="art3_3d_collision" quat="0.707107 0.707107 0 0" type="mesh" mesh="art3_3d_convexhull" contype="1" conaffinity="0" density="0" group="1" class="visualgeom" />
           
            <body name="art4_3d_link" pos="0 -0.0885 0" quat="0.707107 0.707107 0 0">
              <inertial pos="0 0 0.060781" mass="0.001" diaginertia="1.3e-05 1.3e-05 1e-05" />
              <joint name="junta4" pos="0 0 0" axis="0 0 1" range="-1.57 1.57" />
              <geom name="art4_3d_collision" type="mesh" mesh="art4_3d_convexhull" contype="1" conaffinity="0" density="0" group="1" class="visualgeom" />
             
              <body name="art5_3d_link" pos="0 0 0.1045" quat="0.707107 -0.707107 0 0">
                <inertial pos="0 -0.000568 0" quat="0.707107 0 0 0.707107" mass="0.001" diaginertia="1.1e-05 1e-05 1e-05" />
                <joint name="junta5" pos="0 0 0" axis="0 0 1" range="-1.57 1.57" />
                <geom name="art5_3d_collision" quat="0.707107 0.707107 0 0" type="mesh" mesh="art5_3d_convexhull" contype="1" conaffinity="0" density="0" group="1" class="visualgeom" />
                
                <body name="art6_3d_link" pos="0 -0.05 0" quat="0.707107 0.707107 0 0">
                  <inertial pos="0 0 0.006918" mass="0.001" diaginertia="1e-05 1e-05 1e-05" />
                  <joint name="junta6" pos="0 0 0" axis="0 0 1" range="-1.57 1.57" />
                  <geom name="art6_3d_collision" type="mesh" mesh="art6_3d_convexhull" contype="1" conaffinity="0" density="0" group="1" class="visualgeom" />

                  <!-- Ferramenta adicionada (poderia ser um mesh, mas optei por um clindro), não se encontra no .urdf inicial-->
                  <body name="tool" pos="0 0 0.015">
                    <geom type="cylinder" fromto="0 0 0 0 0 0.05" size="0.005" contype="0" conaffinity="0"/>
                    <site name="tool_base" pos="0 0 0" size="0.005"/>
                    <site name="tool_tip" pos="0 0 0.05" size="0.005"/>
                  </body>
                </body>
              </body>
            </body>
          </body>
        </body>
      </body>
    </body>
  </worldbody>

  <actuator>
    <position name="junta1" joint="junta1" kp="100" kv="10" ctrlrange="-1.57 1.57"/>
    <position name="junta2" joint="junta2" kp="100" kv="10" ctrlrange="-1.57 1.57"/>
    <position name="junta3" joint="junta3" kp="100" kv="10" ctrlrange="-1.57 1.57"/>
    <position name="junta4" joint="junta4" kp="100" kv="10" ctrlrange="-1.57 1.57"/>
    <position name="junta5" joint="junta5" kp="100" kv="10" ctrlrange="-1.57 1.57"/>
    <position name="junta6" joint="junta6" kp="100" kv="10" ctrlrange="-1.57 1.57"/>
  </actuator>


  <sensor>
    <actuatorpos name="junta1_p" actuator="junta1" />
    <actuatorvel name="junta1_v" actuator="junta1" />
    <actuatorfrc name="junta1_f" actuator="junta1" noise="0.001" />
    <actuatorpos name="junta2_p" actuator="junta2" />
    <actuatorvel name="junta2_v" actuator="junta2" />
    <actuatorfrc name="junta2_f" actuator="junta2" noise="0.001" />
    <actuatorpos name="junta3_p" actuator="junta3" />
    <actuatorvel name="junta3_v" actuator="junta3" />
    <actuatorfrc name="junta3_f" actuator="junta3" noise="0.001" />
    <actuatorpos name="junta4_p" actuator="junta4" />
    <actuatorvel name="junta4_v" actuator="junta4" />
    <actuatorfrc name="junta4_f" actuator="junta4" noise="0.001" />
    <actuatorpos name="junta5_p" actuator="junta5" />
    <actuatorvel name="junta5_v" actuator="junta5" />
    <actuatorfrc name="junta5_f" actuator="junta5" noise="0.001" />
    <actuatorpos name="junta6_p" actuator="junta6" />
    <actuatorvel name="junta6_v" actuator="junta6" />
    <actuatorfrc name="junta6_f" actuator="junta6" noise="0.001" />
    <framequat name="orientation" objtype="site" noise="0.001" objname="imu" />
    <gyro name="angular-velocity" site="imu" noise="0.005" cutoff="34.9" />

    <!-- sensores adicionados para facilitar a medida de velocidade da ferramenta -->
    <velocimeter site="tool_tip" name="local_linvel"/>
    <accelerometer site="tool_tip" name="accelerometer"/>
    <framezaxis objtype="site" objname="tool_tip" name="upvector"/>
    <framelinvel objtype="site" objname="tool_tip" name="global_linvel"/>
    <frameangvel objtype="site" objname="tool_tip" name="global_angvel"/>
    <framepos objtype="site" objname="tool_tip" name="tool_position"/>
    <framequat objtype="site" objname="tool_tip" name="tool_orientation"/>
  </sensor>
</mujoco>